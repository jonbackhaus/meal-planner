# Meal Planner — environment template  (bd bj1.1 / runbook §3–§5)
#
# The daemon does NOT auto-load this file (no dotenv). Copy it, fill it in, and
# make the values available to the process one of these ways:
#
#   cp .env.example meal-planner.env      # then edit
#   set -a; source ./meal-planner.env; set +a   # export all, then: pnpm dev / pnpm sync
#
# ...or put the values in your launchd plist's EnvironmentVariables (runbook §7).
#
# meal-planner.env (with real secrets) is gitignored — never commit it.
# Secrets can live here (env path) OR in 1Password (op path); see the two blocks
# below and pick ONE.

# ── Required ────────────────────────────────────────────────────────────────
MP_TIMEZONE=America/Chicago          # IANA zone; pins the week boundary + trigger
MP_TRIGGER_TIME=06:00                # 24h HH:MM, weekly fire time (Sunday)

MP_PROFILE=dev                       # dev | prod  (start dev; flip to prod for go-live)
MP_POST_MODE=dry-run                 # dry-run (render+log only) | post (real Slack)

# Channel IDs (the C0… values from bj1.1 Phase E — IDs, never #names):
MP_CHANNEL_ID_DEV=C0DEV_devmealplan     # #dev-meal-plan
MP_CHANNEL_ID_PROD=C0PROD_mealplan      # #meal-plan
MP_ALERTS_CHANNEL_ID=C0ALERTS_agentalerts   # #agent-alerts

# ── Secrets — OPTION A: 1Password (recommended) ─────────────────────────────
# Presence of OP_SERVICE_ACCOUNT_TOKEN auto-selects the 1Password path; the `op`
# CLI must be installed. Store the xoxb-… token and sk-ant-… key as vault fields
# and point these op:// refs at them. Leave Option B unset if you use this.
#OP_SERVICE_ACCOUNT_TOKEN=ops_...
#MP_OP_SLACK_TOKEN_REF=op://Private/meal-planner/slack-bot-token
#MP_OP_ANTHROPIC_KEY_REF=op://Private/meal-planner/anthropic-api-key

# ── Secrets — OPTION B: raw env (simpler) ───────────────────────────────────
# Used only when OP_SERVICE_ACCOUNT_TOKEN is absent. Put the real values in your
# gitignored meal-planner.env, NOT here.
#MP_SLACK_BOT_TOKEN=xoxb-REPLACE_ME
#MP_ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Optional — recipe sync + planner household ──────────────────────────────
#MP_RECIPES_FOLDER=Food               # food-only Notes folder to sync from; NOT a smart folder that also aggregates Drinks (default: Food)
#MP_HOUSEHOLD=                        # override household prose (default encodes the vegetarian constraint)

# ── Optional — first-run / ops ──────────────────────────────────────────────
#MP_FIRE_ON_START=1                   # fire one trigger immediately at boot (test-fire); unset for prod
#MP_LOG_PATH=./data/meal-planner.log  # durable local alert log
#MP_FORCE_REGENERATE=                 # true|false; default dev=true, prod=false
#MP_SQLITE_PATH_DEV=./data/meal-planner.dev.sqlite
#MP_SQLITE_PATH_PROD=./data/meal-planner.prod.sqlite

# ── Optional — model + planner tuning (defaults are safe placeholders) ───────
#MP_MODEL=claude-sonnet-5
#MP_EFFORT=medium                     # low | medium | high | xhigh
#MP_GENERATION_DOLLAR_CAP=2           # hard per-run $ cap; exceeding it fails the run + alerts
#MP_COOK_NIGHTS_CONSTRAINED=4
#MP_COOK_NIGHTS_RELAXED=2
#MP_ACTIVE_MAX_MINUTES=60             # hard active-time filter (open decision b7n)
#MP_FANOUT_MULTIPLIER=4
#MP_VEG_FLOOR_K=2                     # veg-satisfiable floor (open decision kd5)
#MP_UNTESTED_RATE=0.15                # untested-recipe injection rate (open decision kd5)
