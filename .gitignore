
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
.beads/proxieddb/

# Node / build
node_modules/
dist/
*.tsbuildinfo

# Tool caches
.biome-cache/
.vitest-cache/

# Runtime data (SQLite session + recipe index)
data/
# Session-DB backups (bd6.13) + ad-hoc .bak copies (redundant under data/ above,
# listed explicitly so backups are never committed even if data/ is narrowed).
data/backups/
*.bak

# Local secret/env files (never commit real tokens); .env.example is safe
.env
*.env
!.env.example
