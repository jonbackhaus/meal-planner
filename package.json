    "format": "biome format --write .",
    "dev": "tsx watch src/index.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/luxon": "^3.7.2",
    "@types/node": "^22",
    "tsx": "^4.23.0",
    "typescript": "5.9.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.206",
    "@huggingface/transformers": "^4.2.0",
    "better-sqlite3": "^12.11.1",
    "croner": "^10.0.1",
    "luxon": "^3.7.2",
    "sqlite-vec": "^0.1.9",
    "zod": "^4.4.3"
  }
}
